<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1.0" />
  <title>Password Changed</title>
</head>
<body style="margin:0;padding:0;background:#f0f4f8;font-family:'Helvetica Neue',Helvetica,Arial,sans-serif;">
  <div style="display:none;max-height:0;overflow:hidden;mso-hide:all;">Your account password was successfully changed on {{time}}.</div>
  <table width="100%" cellpadding="0" cellspacing="0" role="presentation" style="background:#f0f4f8;padding:40px 16px;">
    <tr>
      <td align="center" valign="top">
        <table width="100%" cellpadding="0" cellspacing="0" style="max-width:560px;" role="presentation">

          <!-- Header -->
          <tr>
            <td style="background:#1a3a5c;padding:28px 40px;border-radius:8px 8px 0 0;text-align:center;">
              <p style="margin:0;color:#93c5fd;font-size:11px;font-weight:600;letter-spacing:2px;text-transform:uppercase;">Security Notice</p>
              <h1 style="margin:8px 0 0;color:#ffffff;font-size:22px;font-weight:700;">Password Changed</h1>
            </td>
          </tr>

          <!-- Body -->
          <tr>
            <td style="background:#ffffff;padding:40px;">
              <p style="margin:0 0 16px;font-size:15px;color:#2d3748;line-height:1.6;">Hello <strong>{{name}}</strong>,</p>
              <p style="margin:0 0 24px;font-size:15px;color:#4a5568;line-height:1.6;">
                Your account password was successfully updated. Here are the details of this change:
              </p>

              <!-- Detail card -->
              <div style="background:#f7fafc;border:1px solid #e2e8f0;border-left:4px solid #38a169;border-radius:6px;padding:20px 24px;margin-bottom:24px;">
                <table width="100%" cellpadding="0" cellspacing="0" role="presentation">
                  <tr>
                    <td width="50%" style="padding-bottom:12px;vertical-align:top;">
                      <p style="margin:0;font-size:11px;font-weight:600;letter-spacing:1.5px;text-transform:uppercase;color:#718096;">Date &amp; Time</p>
                      <p style="margin:4px 0 0;font-size:14px;font-weight:600;color:#1a202c;">{{time}}</p>
                    </td>
                    <td width="50%" style="padding-bottom:12px;vertical-align:top;">
                      <p style="margin:0;font-size:11px;font-weight:600;letter-spacing:1.5px;text-transform:uppercase;color:#718096;">IP Address</p>
                      <p style="margin:4px 0 0;font-size:14px;font-weight:600;color:#1a202c;font-family:'Courier New',monospace;">{{ip}}</p>
                    </td>
                  </tr>
                </table>
              </div>

              <!-- Warning -->
              <div style="background:#fff5f5;border:1px solid #fed7d7;border-radius:6px;padding:14px 16px;">
                <p style="margin:0;font-size:13px;color:#c53030;line-height:1.6;">
                  <strong>⚠ Wasn't you?</strong> If you did not make this change, your account may be compromised.
                  Contact your system administrator immediately.
                </p>
              </div>
            </td>
          </tr>

          <!-- Footer -->
          <tr>
            <td style="background:#2d3748;padding:24px 40px;border-radius:0 0 8px 8px;text-align:center;">
              <p style="margin:0;color:#a0aec0;font-size:12px;line-height:1.6;">This is an automated security notification — do not reply.</p>
            </td>
          </tr>

        </table>
      </td>
    </tr>
  </table>
</body>
</html>
