<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1.0" />
  <title>Welcome to {{facilityName}}</title>
</head>
<body style="margin:0;padding:0;background:#f0f4f8;font-family:'Helvetica Neue',Helvetica,Arial,sans-serif;">
  <div style="display:none;max-height:0;overflow:hidden;mso-hide:all;">Welcome, {{name}} — your patient account has been created successfully.</div>
  <table width="100%" cellpadding="0" cellspacing="0" role="presentation" style="background:#f0f4f8;padding:40px 16px;">
    <tr>
      <td align="center" valign="top">
        <table width="100%" cellpadding="0" cellspacing="0" style="max-width:580px;" role="presentation">

          <!-- Header -->
          <tr>
            <td style="background:#1a3a5c;padding:32px 40px;border-radius:8px 8px 0 0;text-align:center;">
              <p style="margin:0;color:#93c5fd;font-size:11px;font-weight:600;letter-spacing:2px;text-transform:uppercase;">{{facilityName}}</p>
              <h1 style="margin:8px 0 0;color:#ffffff;font-size:24px;font-weight:700;">Welcome!</h1>
              <p style="margin:8px 0 0;color:#bfdbfe;font-size:14px;">Your patient account has been created.</p>
            </td>
          </tr>

          <!-- Body -->
          <tr>
            <td style="background:#ffffff;padding:40px;">
              <p style="margin:0 0 16px;font-size:16px;color:#2d3748;line-height:1.6;">Dear <strong>{{name}}</strong>,</p>
              <p style="margin:0 0 28px;font-size:15px;color:#4a5568;line-height:1.6;">
                We are pleased to welcome you to <strong>{{facilityName}}</strong>. Your patient account has been successfully created. Below are your registration details.
              </p>

              <!-- Patient Info Card -->
              <div style="background:#f0f9ff;border:1px solid #bae6fd;border-radius:8px;padding:24px;margin-bottom:28px;">
                <table width="100%" cellpadding="0" cellspacing="0" role="presentation">
                  <tr>
                    <td width="50%" style="vertical-align:top;padding-right:16px;padding-bottom:12px;">
                      <p style="margin:0;font-size:11px;font-weight:600;letter-spacing:1.5px;text-transform:uppercase;color:#0369a1;">Patient Number</p>
                      <p style="margin:4px 0 0;font-size:20px;font-weight:700;color:#0c4a6e;letter-spacing:1px;">{{patientNumber}}</p>
                    </td>
                    <td width="50%" style="vertical-align:top;padding-bottom:12px;">
                      <p style="margin:0;font-size:11px;font-weight:600;letter-spacing:1.5px;text-transform:uppercase;color:#0369a1;">Registration Date</p>
                      <p style="margin:4px 0 0;font-size:15px;font-weight:600;color:#0c4a6e;">{{registrationDate}}</p>
                    </td>
                  </tr>
                </table>
              </div>

              <!-- What's next -->
              <p style="margin:0 0 16px;font-size:14px;font-weight:700;color:#1a202c;text-transform:uppercase;letter-spacing:0.5px;">Getting Started</p>
              <table width="100%" cellpadding="0" cellspacing="0" role="presentation" style="margin-bottom:28px;">
                <tr>
                  <td style="padding:10px 0;border-bottom:1px solid #f0f4f8;">
                    <table cellpadding="0" cellspacing="0" role="presentation">
                      <tr>
                        <td style="width:32px;vertical-align:top;padding-top:2px;">
                          <div style="width:22px;height:22px;background:#1a3a5c;border-radius:50%;text-align:center;line-height:22px;">
                            <span style="color:#fff;font-size:11px;font-weight:700;">1</span>
                          </div>
                        </td>
                        <td style="vertical-align:top;padding-left:10px;">
                          <p style="margin:0;font-size:14px;font-weight:600;color:#1a202c;">Access your patient portal</p>
                          <p style="margin:2px 0 0;font-size:13px;color:#718096;">View appointments, lab results and billing online.</p>
                        </td>
                      </tr>
                    </table>
                  </td>
                </tr>
                <tr>
                  <td style="padding:10px 0;border-bottom:1px solid #f0f4f8;">
                    <table cellpadding="0" cellspacing="0" role="presentation">
                      <tr>
                        <td style="width:32px;vertical-align:top;padding-top:2px;">
                          <div style="width:22px;height:22px;background:#1a3a5c;border-radius:50%;text-align:center;line-height:22px;">
                            <span style="color:#fff;font-size:11px;font-weight:700;">2</span>
                          </div>
                        </td>
                        <td style="vertical-align:top;padding-left:10px;">
                          <p style="margin:0;font-size:14px;font-weight:600;color:#1a202c;">Keep your patient number safe</p>
                          <p style="margin:2px 0 0;font-size:13px;color:#718096;">You will be asked for it at every visit and consultation.</p>
                        </td>
                      </tr>
                    </table>
                  </td>
                </tr>
                <tr>
                  <td style="padding:10px 0;">
                    <table cellpadding="0" cellspacing="0" role="presentation">
                      <tr>
                        <td style="width:32px;vertical-align:top;padding-top:2px;">
                          <div style="width:22px;height:22px;background:#1a3a5c;border-radius:50%;text-align:center;line-height:22px;">
                            <span style="color:#fff;font-size:11px;font-weight:700;">3</span>
                          </div>
                        </td>
                        <td style="vertical-align:top;padding-left:10px;">
                          <p style="margin:0;font-size:14px;font-weight:600;color:#1a202c;">Contact us whenever you need help</p>
                          <p style="margin:2px 0 0;font-size:13px;color:#718096;">Our patient support team is here for you.</p>
                        </td>
                      </tr>
                    </table>
                  </td>
                </tr>
              </table>

              <!-- CTA -->
              <table width="100%" cellpadding="0" cellspacing="0" role="presentation" style="margin-bottom:28px;">
                <tr>
                  <td align="center">
                    <a href="{{portalLink}}"
                       style="display:inline-block;background:#1a3a5c;color:#ffffff;text-decoration:none;font-size:15px;font-weight:600;padding:14px 36px;border-radius:6px;">
                      Go to Patient Portal
                    </a>
                  </td>
                </tr>
              </table>

              <!-- Contact info -->
              <div style="background:#f7fafc;border:1px solid #e2e8f0;border-radius:6px;padding:16px 20px;">
                <p style="margin:0 0 6px;font-size:13px;font-weight:600;color:#2d3748;">Need assistance?</p>
                {{#if facilityPhone}}<p style="margin:0 0 4px;font-size:13px;color:#718096;">📞 {{facilityPhone}}</p>{{/if}}
                {{#if facilityEmail}}<p style="margin:0 0 4px;font-size:13px;color:#718096;">✉ <a href="mailto:{{facilityEmail}}" style="color:#4299e1;text-decoration:none;">{{facilityEmail}}</a></p>{{/if}}
                {{#if supportEmail}}<p style="margin:0;font-size:13px;color:#718096;">🛟 <a href="mailto:{{supportEmail}}" style="color:#4299e1;text-decoration:none;">{{supportEmail}}</a></p>{{/if}}
              </div>
            </td>
          </tr>

          <!-- Footer -->
          <tr>
            <td style="background:#2d3748;padding:24px 40px;border-radius:0 0 8px 8px;text-align:center;">
              <p style="margin:0;color:#a0aec0;font-size:12px;line-height:1.6;">
                © {{facilityName}}. All rights reserved.<br/>
                This is an automated message — please do not reply.
              </p>
            </td>
          </tr>

        </table>
      </td>
    </tr>
  </table>
</body>
</html>
