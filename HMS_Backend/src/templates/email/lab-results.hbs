<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1.0" />
  <title>Lab Results Ready</title>
</head>
<body style="margin:0;padding:0;background:#f0f4f8;font-family:'Helvetica Neue',Helvetica,Arial,sans-serif;">
  <div style="display:none;max-height:0;overflow:hidden;mso-hide:all;">Your lab results for order #{{orderNumber}} are now available.</div>
  <table width="100%" cellpadding="0" cellspacing="0" role="presentation" style="background:#f0f4f8;padding:40px 16px;">
    <tr>
      <td align="center" valign="top">
        <table width="100%" cellpadding="0" cellspacing="0" style="max-width:600px;" role="presentation">

          <!-- Header -->
          <tr>
            <td style="background:#1a3a5c;padding:28px 40px;border-radius:8px 8px 0 0;text-align:center;">
              <p style="margin:0;color:#93c5fd;font-size:11px;font-weight:600;letter-spacing:2px;text-transform:uppercase;">{{facilityName}}</p>
              <h1 style="margin:8px 0 0;color:#ffffff;font-size:22px;font-weight:700;">Lab Results Available</h1>
            </td>
          </tr>

          <!-- Body -->
          <tr>
            <td style="background:#ffffff;padding:40px;">
              <p style="margin:0 0 16px;font-size:15px;color:#2d3748;line-height:1.6;">Dear <strong>{{patientName}}</strong>,</p>
              <p style="margin:0 0 28px;font-size:15px;color:#4a5568;line-height:1.6;">
                Your laboratory results are now available. Please review the details below and discuss any concerns with your clinician.
              </p>

              <!-- Order Info -->
              <div style="background:#f7fafc;border:1px solid #e2e8f0;border-radius:6px;padding:16px 20px;margin-bottom:24px;">
                <table width="100%" cellpadding="0" cellspacing="0" role="presentation">
                  <tr>
                    <td width="33%" style="vertical-align:top;padding-right:12px;">
                      <p style="margin:0;font-size:11px;font-weight:600;letter-spacing:1px;text-transform:uppercase;color:#718096;">Patient No.</p>
                      <p style="margin:4px 0 0;font-size:14px;font-weight:600;color:#1a202c;">{{patientNumber}}</p>
                    </td>
                    <td width="33%" style="vertical-align:top;padding-right:12px;">
                      <p style="margin:0;font-size:11px;font-weight:600;letter-spacing:1px;text-transform:uppercase;color:#718096;">Order No.</p>
                      <p style="margin:4px 0 0;font-size:14px;font-weight:600;color:#1a202c;">#{{orderNumber}}</p>
                    </td>
                    <td width="33%" style="vertical-align:top;">
                      <p style="margin:0;font-size:11px;font-weight:600;letter-spacing:1px;text-transform:uppercase;color:#718096;">Order Date</p>
                      <p style="margin:4px 0 0;font-size:14px;font-weight:600;color:#1a202c;">{{orderDate}}</p>
                    </td>
                  </tr>
                </table>
              </div>

              <!-- Results Table -->
              <p style="margin:0 0 12px;font-size:13px;font-weight:700;letter-spacing:0.5px;color:#1a202c;text-transform:uppercase;">Results Summary</p>
              <table width="100%" cellpadding="0" cellspacing="0" role="presentation" style="border-radius:6px;overflow:hidden;border:1px solid #e2e8f0;margin-bottom:28px;">
                <!-- Table Header -->
                <tr style="background:#f7fafc;">
                  <td style="padding:10px 14px;font-size:11px;font-weight:700;letter-spacing:1px;text-transform:uppercase;color:#718096;border-bottom:1px solid #e2e8f0;">Test</td>
                  <td style="padding:10px 14px;font-size:11px;font-weight:700;letter-spacing:1px;text-transform:uppercase;color:#718096;border-bottom:1px solid #e2e8f0;">Result</td>
                  <td style="padding:10px 14px;font-size:11px;font-weight:700;letter-spacing:1px;text-transform:uppercase;color:#718096;border-bottom:1px solid #e2e8f0;">Reference Range</td>
                  <td style="padding:10px 14px;font-size:11px;font-weight:700;letter-spacing:1px;text-transform:uppercase;color:#718096;border-bottom:1px solid #e2e8f0;text-align:center;">Status</td>
                </tr>
                {{#each results}}
                <tr style="{{#if @last}}{{else}}border-bottom:1px solid #f0f4f8;{{/if}}">
                  <td style="padding:12px 14px;font-size:13px;color:#2d3748;font-weight:500;">{{this.test}}</td>
                  <td style="padding:12px 14px;font-size:13px;font-weight:600;color:#1a202c;font-family:'Courier New',monospace;">{{this.result}}</td>
                  <td style="padding:12px 14px;font-size:12px;color:#718096;">{{this.reference}}</td>
                  <td style="padding:12px 14px;text-align:center;">
                    {{#if (eq this.flag 'Abnormal')}}
                      <span style="display:inline-block;padding:2px 10px;background:#fff5f5;color:#c53030;border:1px solid #fed7d7;border-radius:12px;font-size:11px;font-weight:700;">Abnormal</span>
                    {{else}}
                      <span style="display:inline-block;padding:2px 10px;background:#f0fff4;color:#276749;border:1px solid #c6f6d5;border-radius:12px;font-size:11px;font-weight:700;">Normal</span>
                    {{/if}}
                  </td>
                </tr>
                {{/each}}
              </table>

              <!-- Disclaimer -->
              <div style="background:#ebf8ff;border:1px solid #bee3f8;border-radius:6px;padding:14px 16px;margin-bottom:28px;">
                <p style="margin:0;font-size:13px;color:#2b6cb0;line-height:1.6;">
                  <strong>Please note:</strong> These results should be interpreted by your healthcare provider in the context of your clinical history.
                  Do not make treatment decisions based solely on these values.
                </p>
              </div>

              <!-- CTA -->
              <table width="100%" cellpadding="0" cellspacing="0" role="presentation">
                <tr>
                  <td align="center">
                    <a href="{{viewLink}}"
                       style="display:inline-block;background:#1a3a5c;color:#ffffff;text-decoration:none;font-size:15px;font-weight:600;padding:14px 36px;border-radius:6px;">
                      View Full Results Online
                    </a>
                  </td>
                </tr>
              </table>
            </td>
          </tr>

          <!-- Footer -->
          <tr>
            <td style="background:#2d3748;padding:24px 40px;border-radius:0 0 8px 8px;text-align:center;">
              <p style="margin:0;color:#a0aec0;font-size:12px;line-height:1.6;">
                {{facilityName}}{{#if facilityPhone}} &nbsp;|&nbsp; {{facilityPhone}}{{/if}}<br/>
                This is an automated message — please do not reply.
              </p>
            </td>
          </tr>

        </table>
      </td>
    </tr>
  </table>
</body>
</html>
