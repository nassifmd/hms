<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1.0" />
  <title>Your Verification Code</title>
</head>
<body style="margin:0;padding:0;background:#f0f4f8;font-family:'Helvetica Neue',Helvetica,Arial,sans-serif;">
  <div style="display:none;max-height:0;overflow:hidden;mso-hide:all;">Your one-time verification code is {{otp}} — expires in {{expiresIn}}.</div>
  <table width="100%" cellpadding="0" cellspacing="0" role="presentation" style="background:#f0f4f8;padding:40px 16px;">
    <tr>
      <td align="center" valign="top">
        <table width="100%" cellpadding="0" cellspacing="0" style="max-width:480px;" role="presentation">

          <!-- Header -->
          <tr>
            <td style="background:#1a3a5c;padding:28px 40px;border-radius:8px 8px 0 0;text-align:center;">
              <p style="margin:0;color:#93c5fd;font-size:11px;font-weight:600;letter-spacing:2px;text-transform:uppercase;">Hospital Management System</p>
              <h1 style="margin:8px 0 0;color:#ffffff;font-size:22px;font-weight:700;">Verification Code</h1>
            </td>
          </tr>

          <!-- Body -->
          <tr>
            <td style="background:#ffffff;padding:40px;text-align:center;">
              <p style="margin:0 0 28px;font-size:15px;color:#4a5568;line-height:1.6;">
                Use the one-time code below to complete your verification.<br/>It will expire in <strong>{{expiresIn}}</strong>.
              </p>

              <!-- OTP Display -->
              <div style="background:#f0f4f8;border:2px solid #e2e8f0;border-radius:10px;padding:28px 24px;margin:0 0 28px;">
                <p style="margin:0;font-size:46px;font-weight:700;letter-spacing:14px;color:#1a3a5c;font-family:'Courier New',Courier,monospace;">{{otp}}</p>
              </div>

              <!-- Warning -->
              <div style="background:#fffbeb;border:1px solid #fcd34d;border-radius:6px;padding:14px 16px;text-align:left;">
                <p style="margin:0;font-size:13px;color:#92400e;line-height:1.5;">
                  <strong>🔒 Keep this code private.</strong> Our staff will <em>never</em> ask for your OTP.
                  If you did not request this, contact support immediately.
                </p>
              </div>
            </td>
          </tr>

          <!-- Footer -->
          <tr>
            <td style="background:#2d3748;padding:20px 40px;border-radius:0 0 8px 8px;text-align:center;">
              <p style="margin:0;color:#a0aec0;font-size:12px;line-height:1.6;">This is an automated message — do not reply.</p>
            </td>
          </tr>

        </table>
      </td>
    </tr>
  </table>
</body>
</html>
