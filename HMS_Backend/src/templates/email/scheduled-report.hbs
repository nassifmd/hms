<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1.0" />
  <title>Scheduled Report Ready — {{titleCase reportType}}</title>
</head>
<body style="margin:0;padding:0;background:#f0f4f8;font-family:'Helvetica Neue',Helvetica,Arial,sans-serif;">
  <div style="display:none;max-height:0;overflow:hidden;mso-hide:all;">Your scheduled {{titleCase reportType}} report is ready to download.</div>
  <table width="100%" cellpadding="0" cellspacing="0" role="presentation" style="background:#f0f4f8;padding:40px 16px;">
    <tr>
      <td align="center" valign="top">
        <table width="100%" cellpadding="0" cellspacing="0" style="max-width:520px;" role="presentation">

          <!-- Header -->
          <tr>
            <td style="background:#1a3a5c;padding:28px 40px;border-radius:8px 8px 0 0;text-align:center;">
              <p style="margin:0;color:#93c5fd;font-size:11px;font-weight:600;letter-spacing:2px;text-transform:uppercase;">Hospital Management System</p>
              <h1 style="margin:8px 0 0;color:#ffffff;font-size:20px;font-weight:700;">Report Ready</h1>
            </td>
          </tr>

          <!-- Body -->
          <tr>
            <td style="background:#ffffff;padding:40px;">

              <p style="margin:0 0 24px;font-size:15px;color:#4a5568;line-height:1.6;">
                Your scheduled report has been generated and is ready for download.
              </p>

              <!-- Report Details Card -->
              <div style="background:#f7fafc;border:1px solid #e2e8f0;border-left:4px solid #3182ce;border-radius:6px;padding:20px 24px;margin-bottom:28px;">
                <table width="100%" cellpadding="0" cellspacing="0" role="presentation">
                  <tr>
                    <td style="padding-bottom:14px;">
                      <p style="margin:0;font-size:11px;font-weight:600;letter-spacing:1.5px;text-transform:uppercase;color:#718096;">Report Type</p>
                      <p style="margin:4px 0 0;font-size:17px;font-weight:700;color:#1a202c;">{{titleCase reportType}}</p>
                    </td>
                  </tr>
                  <tr>
                    <td style="border-top:1px solid #e2e8f0;padding:14px 0;">
                      <table width="100%" cellpadding="0" cellspacing="0" role="presentation">
                        <tr>
                          <td width="50%" style="vertical-align:top;">
                            <p style="margin:0;font-size:11px;font-weight:600;letter-spacing:1.5px;text-transform:uppercase;color:#718096;">Generated</p>
                            <p style="margin:4px 0 0;font-size:14px;font-weight:600;color:#1a202c;">{{generatedAt}}</p>
                          </td>
                          <td width="50%" style="vertical-align:top;">
                            <p style="margin:0;font-size:11px;font-weight:600;letter-spacing:1.5px;text-transform:uppercase;color:#718096;">Format</p>
                            <p style="margin:4px 0 0;">
                              {{#if (eq format 'pdf')}}
                                <span style="display:inline-block;background:#dc2626;color:#ffffff;font-size:11px;font-weight:700;padding:3px 10px;border-radius:12px;text-transform:uppercase;letter-spacing:0.5px;">PDF</span>
                              {{else if (eq format 'excel')}}
                                <span style="display:inline-block;background:#16a34a;color:#ffffff;font-size:11px;font-weight:700;padding:3px 10px;border-radius:12px;text-transform:uppercase;letter-spacing:0.5px;">Excel</span>
                              {{else}}
                                <span style="display:inline-block;background:#4a5568;color:#ffffff;font-size:11px;font-weight:700;padding:3px 10px;border-radius:12px;text-transform:uppercase;letter-spacing:0.5px;">{{upper format}}</span>
                              {{/if}}
                            </p>
                          </td>
                        </tr>
                      </table>
                    </td>
                  </tr>
                </table>
              </div>

              <!-- Download Button -->
              <table width="100%" cellpadding="0" cellspacing="0" role="presentation" style="margin-bottom:28px;">
                <tr>
                  <td align="center">
                    <a href="{{downloadLink}}"
                       style="display:inline-block;background:#1a3a5c;color:#ffffff;text-decoration:none;font-size:15px;font-weight:600;padding:14px 40px;border-radius:6px;letter-spacing:0.3px;">
                      Download Report
                    </a>
                  </td>
                </tr>
              </table>

              <div style="background:#ebf8ff;border:1px solid #bee3f8;border-radius:6px;padding:14px 16px;">
                <p style="margin:0;font-size:13px;color:#2b6cb0;line-height:1.5;">
                  <strong>Note:</strong> Download links expire after 24 hours. If your link has expired, you can regenerate the report from the HMS admin panel.
                </p>
              </div>
            </td>
          </tr>

          <!-- Footer -->
          <tr>
            <td style="background:#2d3748;padding:24px 40px;border-radius:0 0 8px 8px;text-align:center;">
              <p style="margin:0;color:#a0aec0;font-size:12px;line-height:1.6;">
                This is an automated notification from the Hospital Management System.<br/>
                Please do not reply to this email.
              </p>
            </td>
          </tr>

        </table>
      </td>
    </tr>
  </table>
</body>
</html>
